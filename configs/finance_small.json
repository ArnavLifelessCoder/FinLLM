{
  "model": {
    "architecture": "modern",
    "block_size": 256,
    "n_layer": 6,
    "n_head": 6,
    "n_embd": 384,
    "dropout": 0.1,
    "bias": false,
    "norm_type": "rmsnorm",
    "mlp_type": "swiglu",
    "mlp_hidden_mult": 3.5,
    "use_rope": true,
    "num_kv_heads": 2
  },
  "train": {
    "data_dir": "data/finance",
    "tokenizer_model": "finance_tokenizer.model",
    "out_dir": "runs/finance-small",
    "batch_size": 24,
    "gradient_accumulation_steps": 4,
    "max_iters": 2000,
    "eval_interval": 100,
    "eval_iters": 50,
    "log_interval": 10,
    "learning_rate": 0.0003,
    "min_lr": 0.00003,
    "warmup_iters": 100,
    "lr_decay_iters": 2000,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.95,
    "grad_clip": 1.0,
    "seed": 1337,
    "device": "auto",
    "dtype": "auto",
    "compile": false,
    "top_p": 0.95,
    "repetition_penalty": 1.05
  }
}
