{
  "model": {
    "architecture": "modern",
    "block_size": 128,
    "n_layer": 6,
    "n_head": 4,
    "n_embd": 256,
    "dropout": 0.1,
    "bias": false,
    "norm_type": "rmsnorm",
    "mlp_type": "swiglu",
    "mlp_hidden_mult": 3.0,
    "use_rope": true,
    "num_kv_heads": 1
  },
  "train": {
    "data_dir": "data/finance",
    "tokenizer_model": "finance_tokenizer.model",
    "out_dir": "runs/finance-modern-cpu",
    "batch_size": 6,
    "gradient_accumulation_steps": 8,
    "max_iters": 3000,
    "eval_interval": 100,
    "eval_iters": 25,
    "log_interval": 10,
    "learning_rate": 0.0004,
    "min_lr": 0.00004,
    "warmup_iters": 100,
    "lr_decay_iters": 3000,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.95,
    "grad_clip": 1.0,
    "seed": 1337,
    "device": "cpu",
    "dtype": "float32",
    "compile": false,
    "cpu_threads": 8,
    "top_p": 0.95,
    "repetition_penalty": 1.08
  }
}
